#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
env_file="${1:-${repo_root}/.env.production}"

if [[ ! -f "${env_file}" ]]; then
  echo "env file not found: ${env_file}" >&2
  exit 1
fi
if ! command -v openssl >/dev/null 2>&1; then
  echo "openssl is required for secret fingerprint validation" >&2
  exit 1
fi

set -a
# shellcheck disable=SC1090
source "${env_file}"
set +a

: "${GCP_PROJECT_ID:?GCP_PROJECT_ID is required}"
: "${CLICKHOUSE_URL:?CLICKHOUSE_URL is required}"
: "${CLICKHOUSE_PASSWORD:?CLICKHOUSE_PASSWORD is required}"
: "${ALCHEMY_WORLDCHAIN_RPC_URL:?ALCHEMY_WORLDCHAIN_RPC_URL is required}"
: "${ALCHEMY_WORLDCHAIN_WS_URL:?ALCHEMY_WORLDCHAIN_WS_URL is required}"
: "${ALCHEMY_OPTIMISM_RPC_URL:?ALCHEMY_OPTIMISM_RPC_URL is required}"
: "${BINANCE_API_KEY:?BINANCE_API_KEY is required}"
: "${BINANCE_SECRET_KEY:?BINANCE_SECRET_KEY is required}"

gcloud_local="${repo_root}/scripts/gcloud-local"
"${gcloud_local}" config set project "${GCP_PROJECT_ID}" >/dev/null
"${gcloud_local}" services enable secretmanager.googleapis.com >/dev/null

sync_secret() {
  local name="$1"
  local value="$2"

  if "${gcloud_local}" secrets describe "${name}" >/dev/null 2>&1; then
    local current
    local current_fingerprint
    local requested_fingerprint
    current="$("${gcloud_local}" secrets versions access latest --secret="${name}")"
    current_fingerprint="$(printf '%s' "${current}" | openssl dgst -sha256 | awk '{print $2}')"
    requested_fingerprint="$(printf '%s' "${value}" | openssl dgst -sha256 | awk '{print $2}')"
    if [[ "${current_fingerprint}" == "${requested_fingerprint}" ]]; then
      echo "kept matching enabled version: ${name}"
    elif [[ "${GCP_SECRET_ROTATION_CONFIRMATION:-}" == "ROTATE_EXISTING_SECRET_VERSIONS" ]]; then
      printf '%s' "${value}" \
        | "${gcloud_local}" secrets versions add "${name}" --data-file=- >/dev/null
      echo "added explicitly confirmed new version: ${name}"
    else
      echo "local value differs from Secret Manager latest: ${name}" >&2
      echo "update the env file, or set GCP_SECRET_ROTATION_CONFIRMATION=ROTATE_EXISTING_SECRET_VERSIONS for an intentional rotation" >&2
      exit 1
    fi
  else
    printf '%s' "${value}" \
      | "${gcloud_local}" secrets create "${name}" \
          --replication-policy=automatic \
          --data-file=- >/dev/null
    echo "created secret: ${name}"
  fi
}

sync_or_require_existing_secret() {
  local name="$1"
  local value="${!name:-}"

  if [[ -n "${value}" ]]; then
    sync_secret "${name}" "${value}"
  elif "${gcloud_local}" secrets versions describe latest \
    --secret="${name}" \
    --format='value(state)' 2>/dev/null | grep -qx ENABLED; then
    echo "kept existing enabled version: ${name}"
  else
    echo "${name} is absent locally and has no enabled Secret Manager version" >&2
    exit 1
  fi
}

sync_secret CLICKHOUSE_URL "${CLICKHOUSE_URL}"
sync_secret CLICKHOUSE_PASSWORD "${CLICKHOUSE_PASSWORD}"
sync_secret ALCHEMY_WORLDCHAIN_RPC_URL "${ALCHEMY_WORLDCHAIN_RPC_URL}"
sync_secret ALCHEMY_WORLDCHAIN_WS_URL "${ALCHEMY_WORLDCHAIN_WS_URL}"
sync_secret ALCHEMY_OPTIMISM_RPC_URL "${ALCHEMY_OPTIMISM_RPC_URL}"
sync_secret BINANCE_API_KEY "${BINANCE_API_KEY}"
sync_secret BINANCE_SECRET_KEY "${BINANCE_SECRET_KEY}"
sync_or_require_existing_secret EVM_WALLET_PRIVATE_KEY
if [[ -n "${BINANCE_TREASURY_API_KEY:-}" || -n "${BINANCE_TREASURY_SECRET_KEY:-}" ]]; then
  : "${BINANCE_TREASURY_API_KEY:?both treasury credential values are required}"
  : "${BINANCE_TREASURY_SECRET_KEY:?both treasury credential values are required}"
  sync_or_require_existing_secret BINANCE_TREASURY_API_KEY
  sync_or_require_existing_secret BINANCE_TREASURY_SECRET_KEY
fi
