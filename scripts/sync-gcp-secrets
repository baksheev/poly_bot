#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
env_file="${1:-${repo_root}/.env.production}"

if [[ ! -f "${env_file}" ]]; then
  echo "env file not found: ${env_file}" >&2
  exit 1
fi

set -a
# shellcheck disable=SC1090
source "${env_file}"
set +a

: "${GCP_PROJECT_ID:?GCP_PROJECT_ID is required}"
: "${CLICKHOUSE_URL:?CLICKHOUSE_URL is required}"
: "${CLICKHOUSE_PASSWORD:?CLICKHOUSE_PASSWORD is required}"
: "${ALCHEMY_WORLDCHAIN_RPC_URL:?ALCHEMY_WORLDCHAIN_RPC_URL is required}"
: "${ALCHEMY_WORLDCHAIN_WS_URL:?ALCHEMY_WORLDCHAIN_WS_URL is required}"
: "${BINANCE_API_KEY:?BINANCE_API_KEY is required}"
: "${BINANCE_SECRET_KEY:?BINANCE_SECRET_KEY is required}"

gcloud_local="${repo_root}/scripts/gcloud-local"
"${gcloud_local}" config set project "${GCP_PROJECT_ID}" >/dev/null
"${gcloud_local}" services enable secretmanager.googleapis.com >/dev/null

sync_secret() {
  local name="$1"
  local value="$2"

  if "${gcloud_local}" secrets describe "${name}" >/dev/null 2>&1; then
    printf '%s' "${value}" \
      | "${gcloud_local}" secrets versions add "${name}" --data-file=- >/dev/null
    echo "added a new version: ${name}"
  else
    printf '%s' "${value}" \
      | "${gcloud_local}" secrets create "${name}" \
          --replication-policy=automatic \
          --data-file=- >/dev/null
    echo "created secret: ${name}"
  fi
}

sync_secret CLICKHOUSE_URL "${CLICKHOUSE_URL}"
sync_secret CLICKHOUSE_PASSWORD "${CLICKHOUSE_PASSWORD}"
sync_secret ALCHEMY_WORLDCHAIN_RPC_URL "${ALCHEMY_WORLDCHAIN_RPC_URL}"
sync_secret ALCHEMY_WORLDCHAIN_WS_URL "${ALCHEMY_WORLDCHAIN_WS_URL}"
sync_secret BINANCE_API_KEY "${BINANCE_API_KEY}"
sync_secret BINANCE_SECRET_KEY "${BINANCE_SECRET_KEY}"
