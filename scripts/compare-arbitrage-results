#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
env_file="${ENV_FILE:-${repo_root}/.env.production}"
start_utc="${1:-}"
end_utc="${2:-}"

if [[ ! "${start_utc}" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$ \
  || ! "${end_utc}" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$ ]]; then
  echo "usage: scripts/compare-arbitrage-results START_UTC END_UTC" >&2
  echo "timestamps must use YYYY-MM-DDTHH:MM:SSZ" >&2
  exit 1
fi
if [[ ! -f "${env_file}" ]]; then
  echo "env file not found: ${env_file}" >&2
  exit 1
fi

set -a
# shellcheck disable=SC1090
source "${env_file}"
set +a

: "${ARB_BOT_DATABASE_URL:?ARB_BOT_DATABASE_URL is required}"
: "${CLICKHOUSE_URL:?CLICKHOUSE_URL is required}"
: "${CLICKHOUSE_PASSWORD:?CLICKHOUSE_PASSWORD is required}"
clickhouse_user="${CLICKHOUSE_USER:-default}"
start_ch="${start_utc/T/ }"
start_ch="${start_ch%Z}"
end_ch="${end_utc/T/ }"
end_ch="${end_ch%Z}"

echo "runtime|completed_trades|profitable_trades|comparable_usdc|avg_comparable_usdc|absolute_wld_residual"
psql "${ARB_BOT_DATABASE_URL}" \
  -X \
  --no-psqlrc \
  -v ON_ERROR_STOP=1 \
  --set="start_utc=${start_utc}" \
  --set="end_utc=${end_utc}" \
  -qAt \
  -F '|' \
  -f "${repo_root}/scripts/sql/rails_arbitrage_comparison.sql"

clickhouse_query="
SELECT
    'rust' AS runtime,
    count() AS completed_trades,
    countIf(JSONExtractString(payload_json, 'outcome') = 'balanced_profit') AS profitable_trades,
    sum(toInt128OrZero(JSONExtractString(payload_json, 'comparable_profit_token_a_base_units'))) / 1000000 AS comparable_usdc,
    if(count() = 0, 0, avg(toInt128OrZero(JSONExtractString(payload_json, 'comparable_profit_token_a_base_units'))) / 1000000) AS avg_comparable_usdc,
    sum(abs(toInt128OrZero(JSONExtractString(payload_json, 'token_b_residual_base_units')))) / 1000000000000000000 AS absolute_wld_residual
FROM arb_bot_prod.runtime_telemetry
WHERE kind = 'arbitrage_result'
  AND JSONExtractString(payload_json, 'pair_id') = 'world-chain-usdc-wld'
  AND JSONExtractString(payload_json, 'execution_mode') = 'dex_first'
  AND observed_at_ms >= toUnixTimestamp64Milli(toDateTime64('${start_ch}', 3, 'UTC'))
  AND observed_at_ms < toUnixTimestamp64Milli(toDateTime64('${end_ch}', 3, 'UTC'))
FORMAT TabSeparated
"
curl --fail --silent --show-error \
  --user "${clickhouse_user}:${CLICKHOUSE_PASSWORD}" \
  --data-binary "${clickhouse_query}" \
  "${CLICKHOUSE_URL}" | tr '\t' '|'

audit_query="
SELECT
    (
        SELECT uniqExactIf(JSONExtractString(payload_json, 'plan_id'), kind = 'arbitrage_admitted')
        FROM arb_bot_prod.runtime_telemetry
        WHERE observed_at_ms >= toUnixTimestamp64Milli(toDateTime64('${start_ch}', 3, 'UTC'))
          AND observed_at_ms < toUnixTimestamp64Milli(toDateTime64('${end_ch}', 3, 'UTC'))
    ) AS admitted,
    (
        SELECT uniqExactIf(JSONExtractString(payload_json, 'plan_id'), kind = 'arbitrage_result')
        FROM arb_bot_prod.runtime_telemetry
        WHERE observed_at_ms >= toUnixTimestamp64Milli(toDateTime64('${start_ch}', 3, 'UTC'))
          AND observed_at_ms < toUnixTimestamp64Milli(toDateTime64('${end_ch}', 3, 'UTC'))
    ) AS balanced,
    countIf(blocked_at > 0 AND blocked_at > result_at) AS blocked_unknown
FROM
(
    SELECT
        JSONExtractString(payload_json, 'plan_id') AS plan_id,
        maxIf(observed_at_ms, kind = 'arbitrage_inventory_state' AND JSONExtractString(payload_json, 'state') = 'BlockedUnknown') AS blocked_at,
        maxIf(observed_at_ms, kind = 'arbitrage_result') AS result_at
    FROM arb_bot_prod.runtime_telemetry
    WHERE observed_at_ms >= toUnixTimestamp64Milli(toDateTime64('${start_ch}', 3, 'UTC'))
      AND observed_at_ms < toUnixTimestamp64Milli(toDateTime64('${end_ch}', 3, 'UTC'))
      AND kind IN ('arbitrage_result', 'arbitrage_inventory_state')
    GROUP BY plan_id
)
WHERE plan_id != ''
FORMAT TabSeparated
"
echo "rust_admitted|rust_balanced|rust_blocked_unknown"
curl --fail --silent --show-error \
  --user "${clickhouse_user}:${CLICKHOUSE_PASSWORD}" \
  --data-binary "${audit_query}" \
  "${CLICKHOUSE_URL}" | tr '\t' '|'
