#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
env_file="${ENV_FILE:-${repo_root}/.env.production}"
image="${1:-}"
source_revision="${2:-}"
execution_mode="${3:-paper_dex_first}"

if [[ -z "${image}" || -z "${source_revision}" ]]; then
  echo "usage: scripts/update-gce-worker IMAGE SOURCE_REVISION [disabled|paper_dex_first|full_live]" >&2
  exit 1
fi
if [[ ! -f "${env_file}" ]]; then
  echo "env file not found: ${env_file}" >&2
  exit 1
fi
if [[ -n "$(git -C "${repo_root}" status --porcelain)" ]]; then
  echo "refusing to deploy from a dirty worktree" >&2
  exit 1
fi
if [[ ! "${image}" =~ @sha256:[0-9a-f]{64}$ ]]; then
  echo "IMAGE must be pinned by sha256 digest" >&2
  exit 1
fi
if [[ ! "${source_revision}" =~ ^[a-z0-9-]{1,63}$ ]]; then
  echo "SOURCE_REVISION must be a valid lowercase GCP label value" >&2
  exit 1
fi
if [[ ! "${execution_mode}" =~ ^(disabled|paper_dex_first|full_live)$ ]]; then
  echo "execution mode must be disabled, paper_dex_first, or full_live" >&2
  exit 1
fi

set -a
# shellcheck disable=SC1090
source "${env_file}"
set +a

: "${GCP_PROJECT_ID:?GCP_PROJECT_ID is required}"
: "${GCP_REGION:?GCP_REGION is required}"
: "${EVM_WALLET_ADDRESS:?EVM_WALLET_ADDRESS is required}"

domain_config_path="config/strategies/usdc-wld-world-chain.v4.json"
live_confirmation=""
max_plan_cost=0
max_recovery_loss=0
max_cumulative_loss=0
max_cumulative_recovery_loss=0
max_total_entries=0
max_entries_per_minute=0
mode_label="${execution_mode//_/-}"

if [[ "${execution_mode}" == "full_live" ]]; then
  domain_config_path="${ARBITRAGE_LIVE_DOMAIN_CONFIG_PATH:-config/strategies/usdc-wld-world-chain.v5.json}"
  live_confirmation="${ARBITRAGE_LIVE_CONFIRMATION:-}"
  max_plan_cost="${ARBITRAGE_MAX_PLAN_COST_TOKEN_A_BASE_UNITS:-0}"
  max_recovery_loss="${ARBITRAGE_MAX_RECOVERY_LOSS_TOKEN_A_BASE_UNITS:-0}"
  max_cumulative_loss="${ARBITRAGE_MAX_CUMULATIVE_LOSS_TOKEN_A_BASE_UNITS:-0}"
  max_cumulative_recovery_loss="${ARBITRAGE_MAX_CUMULATIVE_RECOVERY_LOSS_TOKEN_A_BASE_UNITS:-0}"
  max_total_entries="${ARBITRAGE_MAX_TOTAL_ENTRIES:-0}"
  max_entries_per_minute="${ARBITRAGE_MAX_ENTRIES_PER_MINUTE:-0}"
  if [[ "${live_confirmation}" != "ENABLE_FULL_LIVE_ARBITRAGE" ]]; then
    echo "full_live requires ARBITRAGE_LIVE_CONFIRMATION=ENABLE_FULL_LIVE_ARBITRAGE" >&2
    exit 1
  fi
  if [[ "${domain_config_path}" != "config/strategies/usdc-wld-world-chain.v5.json" ]]; then
    echo "full_live requires ARBITRAGE_LIVE_DOMAIN_CONFIG_PATH=config/strategies/usdc-wld-world-chain.v5.json" >&2
    exit 1
  fi
  for value in \
    "${max_plan_cost}" \
    "${max_recovery_loss}" \
    "${max_cumulative_loss}" \
    "${max_cumulative_recovery_loss}" \
    "${max_total_entries}" \
    "${max_entries_per_minute}"; do
    if [[ ! "${value}" =~ ^[1-9][0-9]*$ ]]; then
      echo "full_live requires every arbitrage risk limit to be a positive integer" >&2
      exit 1
    fi
  done
  if (( max_total_entries > 100 || max_entries_per_minute > 10 )); then
    echo "full_live total/rate limits exceed the launch envelope" >&2
    exit 1
  fi
fi

gcloud_local="${repo_root}/scripts/gcloud-local"
zone="${GCE_ZONE:-${GCP_REGION}-b}"
instance="arb-bot-rust-shadow-gce"
runtime_service_account="arb-bot-runtime@${GCP_PROJECT_ID}.iam.gserviceaccount.com"
engine_id="arb-bot-rust-${mode_label}-gce-${source_revision}"

"${gcloud_local}" compute instances describe "${instance}" --zone="${zone}" >/dev/null
if [[ "${execution_mode}" == "full_live" ]]; then
  audit_kube_dir="$(mktemp -d)"
  export KUBECONFIG="${audit_kube_dir}/config"
  "${gcloud_local}" container clusters get-credentials arb-bot \
    --zone="${zone}" >/dev/null
  competing_replicas="$(kubectl get deployment arb-bot \
    --namespace=arb-bot \
    --output='jsonpath={.spec.replicas}')"
  rm -r "${audit_kube_dir}"
  unset KUBECONFIG
  if [[ "${competing_replicas}" != "0" ]]; then
    echo "full_live requires the competing GKE arb-bot deployment to be scaled to zero" >&2
    exit 1
  fi
  "${gcloud_local}" secrets add-iam-policy-binding EVM_WALLET_PRIVATE_KEY \
    --member="serviceAccount:${runtime_service_account}" \
    --role=roles/secretmanager.secretAccessor \
    --quiet >/dev/null
fi
"${gcloud_local}" compute instances add-metadata "${instance}" \
  --zone="${zone}" \
  --metadata="arb-bot-image=${image},arb-bot-engine-id=${engine_id},arb-bot-region=${GCP_REGION},arb-bot-wallet-address=${EVM_WALLET_ADDRESS},arb-bot-domain-config-path=${domain_config_path},arb-bot-arbitrage-execution-mode=${execution_mode},arb-bot-arbitrage-live-confirmation=${live_confirmation},arb-bot-arbitrage-max-plan-cost=${max_plan_cost},arb-bot-arbitrage-max-recovery-loss=${max_recovery_loss},arb-bot-arbitrage-max-cumulative-loss=${max_cumulative_loss},arb-bot-arbitrage-max-cumulative-recovery-loss=${max_cumulative_recovery_loss},arb-bot-arbitrage-max-total-entries=${max_total_entries},arb-bot-arbitrage-max-entries-per-minute=${max_entries_per_minute}" \
  --metadata-from-file="startup-script=${repo_root}/infra/gcp/gce-startup.sh"
"${gcloud_local}" compute instances add-labels "${instance}" \
  --zone="${zone}" \
  --labels="component=trading,mode=${mode_label},source-revision=${source_revision}"

status="$("${gcloud_local}" compute instances describe "${instance}" \
  --zone="${zone}" \
  --format='value(status)')"
if [[ "${status}" == "TERMINATED" ]]; then
  "${gcloud_local}" compute instances start "${instance}" --zone="${zone}" --quiet
else
  "${gcloud_local}" compute ssh "${instance}" \
    --zone="${zone}" \
    --tunnel-through-iap \
    --command='sudo google_metadata_script_runner startup'
fi

echo "updated ${instance} to ${image} in ${execution_mode} mode"
