SERVICE_NAME=arb-bot-rust-shadow
ENGINE_ID=arb-bot-rust-shadow-local
GCP_PROJECT_ID=poly-bot-502515

GCP_REGION=asia-southeast1

BINANCE_WS_BASE_URL=wss://stream.binance.com:9443/ws
# Full rebalance uses the isolated subaccount trading key plus a master treasury key.
# The master key requires Reading, Withdrawals, Universal Transfer, and the production IP allowlist.
BINANCE_TREASURY_API_KEY=
BINANCE_TREASURY_SECRET_KEY=
# Kept in Secret Manager because this is an account identifier.
BINANCE_SUBACCOUNT_EMAIL=
ACROSS_API_BASE_URL=https://app.across.to/api
ALCHEMY_WORLDCHAIN_RPC_URL=
ALCHEMY_WORLDCHAIN_WS_URL=
ALCHEMY_OPTIMISM_RPC_URL=
# Public address only. The read-only balance synchronizer never loads a signer.
EVM_WALLET_ADDRESS=
# Required only by explicitly gated local EVM mutation commands.
EVM_WALLET_JOURNAL_PATH=
# Required only by the full live rebalance executor; never commit the value.
EVM_WALLET_PRIVATE_KEY=
# Exact acknowledgement required by the capped manual Uniswap round-trip command.
UNISWAP_LIVE_CONFIRMATION=
BINANCE_ORDER_JOURNAL_PATH=
BINANCE_LIVE_CONFIRMATION=
DOMAIN_CONFIG_PATH=config/strategies/usdc-wld-world-chain.v4.json
MARKET_DATA_MAX_AGE_MS=5000
DEX_EVENT_CHANNEL_CAPACITY=8192
DEX_HEAD_MAX_AGE_MS=10000
BALANCE_SYNC_INTERVAL_MS=1000
BALANCE_MAX_AGE_MS=5000
BALANCE_EVENT_CHANNEL_CAPACITY=16
# full_live additionally requires the exact confirmation, positive risk caps,
# and both reviewed gates in the versioned domain artifact.
ARBITRAGE_EXECUTION_MODE=disabled
ARBITRAGE_LIVE_CONFIRMATION=
ARBITRAGE_TRADE_JOURNAL_PATH=/var/lib/arb-bot/arbitrage-trades.jsonl
ARBITRAGE_EXECUTION_CHANNEL_CAPACITY=64
# Full-live startup rejects zero limits. Recovery remains enabled when the stop file exists.
ARBITRAGE_MAX_PLAN_COST_TOKEN_A_BASE_UNITS=0
ARBITRAGE_MAX_RECOVERY_LOSS_TOKEN_A_BASE_UNITS=0
ARBITRAGE_MAX_CUMULATIVE_LOSS_TOKEN_A_BASE_UNITS=0
ARBITRAGE_MAX_CUMULATIVE_RECOVERY_LOSS_TOKEN_A_BASE_UNITS=0
# Durable journal lifetime cap: 1 for composed canary, then 100 for the goal run.
ARBITRAGE_MAX_TOTAL_ENTRIES=0
ARBITRAGE_MAX_ENTRIES_PER_MINUTE=0
ARBITRAGE_ENTRY_STOP_FILE=/var/run/arb-bot/arbitrage-entry.stop
REBALANCE_EXECUTION_MODE=disabled
REBALANCE_EXECUTOR_JOURNAL_PATH=/var/lib/arb-bot/rebalance-executor.jsonl
REBALANCE_EXECUTOR_TIMEOUT_SECONDS=1800
REBALANCE_MAX_WLD_AMOUNT=0
REBALANCE_MAX_USDC_AMOUNT=0
REBALANCE_LIVE_CONFIRMATION=
REBALANCE_BINANCE_WITHDRAWAL_API_MODE=standard

# Leave empty to run locally with log-only telemetry.
CLICKHOUSE_URL=
CLICKHOUSE_DATABASE=arb_bot
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

TELEMETRY_CHANNEL_CAPACITY=8192
TELEMETRY_BATCH_SIZE=200
TELEMETRY_FLUSH_INTERVAL_MS=100
RUST_LOG=arb_bot=info
