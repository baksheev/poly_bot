{
  "project_id": "poly-bot-502515",
  "region": "asia-southeast1",
  "artifact_repo": "poly-bot",
  "image_name": "poly-bot",
  "runtime_service_account": "REPLACE_WITH_RUNTIME_SERVICE_ACCOUNT",
  "worker_pools": [
    {
      "name": "arb-bot-rust-shadow",
      "command": ["run"],
      "instances": 1,
      "cpu": "8",
      "memory": "16Gi",
      "env": {
        "ENGINE_ID": "arb-bot-rust-shadow-gcp",
        "GCP_REGION": "asia-southeast1",
        "BINANCE_WS_BASE_URL": "wss://stream.binance.com:9443/ws",
        "DOMAIN_CONFIG_PATH": "config/strategies/usdc-wld-world-chain.v2.json",
        "MARKET_DATA_MAX_AGE_MS": "5000",
        "DEX_EVENT_CHANNEL_CAPACITY": "8192",
        "DEX_HEAD_MAX_AGE_MS": "10000",
        "CLICKHOUSE_DATABASE": "arb_bot_prod",
        "TELEMETRY_CHANNEL_CAPACITY": "8192",
        "TELEMETRY_BATCH_SIZE": "200",
        "TELEMETRY_FLUSH_INTERVAL_MS": "100"
      },
      "secrets": [
        "CLICKHOUSE_URL",
        "CLICKHOUSE_PASSWORD",
        "ALCHEMY_WORLDCHAIN_RPC_URL",
        "ALCHEMY_WORLDCHAIN_WS_URL"
      ]
    }
  ]
}
